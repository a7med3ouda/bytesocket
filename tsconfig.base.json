{
	"compilerOptions": {
		"target": "es2024",
		"module": "esnext",
		"lib": ["es2024"],
		"moduleResolution": "bundler",
		"ignoreDeprecations": "6.0",
		"strict": true,
		"declaration": true,
		"skipLibCheck": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true
	},
	"exclude": ["**/node_modules/**", "**/dist/**"]
}
