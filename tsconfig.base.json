{
	"compilerOptions": {
		"target": "es2024",
		"module": "esnext",
		"lib": ["es2024"],
		"moduleResolution": "bundler",
		"strict": true,
		"declaration": true,
		"skipLibCheck": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["vitest/globals"]
	},
	"exclude": ["**/node_modules/**", "**/dist/**"]
}
