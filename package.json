{
	"name": "bytesocket",
	"private": true,
	"scripts": {
		"build": "pnpm -r build",
		"build:fix": "pnpm i && pnpm clean && pnpm format:fix && pnpm lint:fix && pnpm build",
		"clean": "pnpm -r clean",
		"dev": "pnpm -r dev",
		"format": "prettier \"**/*.{js,ts,mjs,mts,cjs,cts,json,jsonc,yaml,yml,md}\" --check",
		"format:fix": "prettier \"**/*.{js,ts,mjs,mts,cjs,cts,json,jsonc,yaml,yml,md}\" --write",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepare": "husky",
		"test": "vitest",
		"test:client": "vitest packages/client",
		"test:coverage": "vitest --coverage",
		"test:node": "vitest packages/node",
		"test:ui": "vitest --ui",
		"test:uws": "vitest packages/uws"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/ws": "catalog:",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"prettier": "^3.8.3",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.5",
		"ws": "catalog:"
	}
}
