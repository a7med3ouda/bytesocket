{
	"name": "@bytesocket/uws",
	"version": "0.1.0",
	"description": "High-performance WebSocket server for Node.js using uWebSockets.js",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf dist",
		"dev": "tsup --watch"
	},
	"dependencies": {
		"@bytesocket/types": "workspace:*",
		"msgpackr": "catalog:"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.61.0"
	}
}
