{
	"name": "@bytesocket/node",
	"version": "0.3.0",
	"description": "Framework-agnostic WebSocket server for Node.js using the native http.Server upgrade API",
	"keywords": [
		"websocket",
		"socket",
		"realtime",
		"bytesocket",
		"node",
		"http-server",
		"ws",
		"msgpack",
		"binary",
		"fastify",
		"express",
		"koa",
		"nestjs"
	],
	"homepage": "https://github.com/a7med3ouda/bytesocket/tree/main/packages/node",
	"bugs": {
		"url": "https://github.com/a7med3ouda/bytesocket/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/a7med3ouda/bytesocket.git",
		"directory": "packages/node"
	},
	"license": "MIT",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"clean": "rm -rf dist",
		"dev": "tsup --watch"
	},
	"dependencies": {
		"@bytesocket/core": "workspace:*",
		"@bytesocket/types": "workspace:*",
		"ws": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/ws": "catalog:"
	},
	"engines": {
		"node": ">=22.4.0"
	}
}
