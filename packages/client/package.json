{
	"name": "@bytesocket/client",
	"version": "0.1.0",
	"description": "High-performance WebSocket client for browsers",
	"type": "module",
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"main": "./dist/index.cjs",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"msgpackr": "catalog:"
	}
}
